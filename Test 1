def get_excel_engine(path: Path):
    ext = path.suffix.lower()
    if ext == ".xls":
        return "xlrd"
    elif ext == ".xlsx":
        return "openpyxl"
    else:
        raise ValueError(f"Unsupported Excel type: {ext}")


def safe_float(val):
    try:
        if pd.isna(val) or str(val).strip() == "":
            return None
        return float(val)
    except Exception:
        return None


def clean_string(val):
    if pd.isna(val):
        return ""
    return str(val).strip()


def normalize_key(s: str) -> str:
    return " ".join(str(s).replace("\n", " ").replace("\r", " ").split()).strip().lower()


def set_cell_shading(cell, fill):
    tc_pr = cell._tc.get_or_add_tcPr()
    shd = OxmlElement("w:shd")
    shd.set(qn("w:fill"), fill)
    tc_pr.append(shd)


def set_cell_text(cell, text, bold=False, font_size=9, align="left"):
    cell.text = ""
    p = cell.paragraphs[0]

    if align == "center":
        p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    elif align == "right":
        p.alignment = WD_ALIGN_PARAGRAPH.RIGHT
    else:
        p.alignment = WD_ALIGN_PARAGRAPH.LEFT

    if text is None or str(text).strip() == "":
        text = "N/A"

    run = p.add_run(str(text))
    run.bold = bold
    run.font.size = Pt(font_size)
    cell.vertical_alignment = WD_CELL_VERTICAL_ALIGNMENT.CENTER


def format_number(val, decimals=1):
    if val is None:
        return "N/A"
    try:
        if isinstance(val, float) and (math.isnan(val) or math.isinf(val)):
            return "N/A"
    except Exception:
        pass
    return f"{val:.{decimals}f}"


def build_metadata_dict(header_values, data_values):
    meta = {}
    for h, v in zip(header_values, data_values):
        header = clean_string(h)
        if header:
            meta[header] = v
    return meta


def lookup_meta(meta, possible_names, default="N/A"):
    normalized = {normalize_key(k): v for k, v in meta.items()}
    for name in possible_names:
        key = normalize_key(name)
        if key in normalized:
            val = normalized[key]
            if pd.isna(val) or str(val).strip() == "":
                return default
            return val
    return default


def add_title_block(document):
    p = document.add_paragraph()
    p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    r = p.add_run(report_title)
    r.bold = True
    r.font.size = Pt(16)

    p2 = document.add_paragraph()
    p2.alignment = WD_ALIGN_PARAGRAPH.CENTER
    r2 = p2.add_run(report_subtitle)
    r2.italic = True
    r2.font.size = Pt(10)

    p3 = document.add_paragraph()
    p3.alignment = WD_ALIGN_PARAGRAPH.LEFT
    r3 = p3.add_run(f"Prepared by: {prepared_by}")
    r3.bold = True
    r3.font.size = Pt(10)


def plot_and_save(displacement, load, strain, stress):
    temp_dir = Path(tempfile.gettempdir())
    plot1_path = temp_dir / "load_vs_displacement_report.png"
    plot2_path = temp_dir / "stress_vs_strain_report.png"

    plt.figure(figsize=(5.8, 4.5))
    plt.plot(displacement, load)
    plt.xlabel("Displacement (mm)")
    plt.ylabel("Load (N)")
    plt.title("Load vs Displacement")
    plt.grid(True)
    plt.tight_layout()
    plt.savefig(plot1_path, dpi=200, bbox_inches="tight")
    plt.close()

    plt.figure(figsize=(5.8, 4.5))
    plt.plot(strain, stress)
    plt.xlabel("Strain (mm/mm)")
    plt.ylabel("Stress (MPa)")
    plt.title("Stress vs Strain")
    plt.grid(True)
    plt.tight_layout()
    plt.savefig(plot2_path, dpi=200, bbox_inches="tight")
    plt.close()

    return plot1_path, plot2_path


