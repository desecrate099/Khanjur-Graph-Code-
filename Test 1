import pandas as pd
import matplotlib.pyplot as plt
from pathlib import Path

# ----------------------------- USER SETTINGS -----------------------------
file_path = Path(r"C:\Users\sprid\Downloads\SMAstrain.xls")  # <-- now works

start = 10
end = None

sheet_colors = {
    # "Sheet1": "red",
}

x_axis = "POSITION mm"
y_axis = "LOAD N"

plot_title = "Room T 100 microns"

label_fontsize = 20
title_fontsize = 20
tick_fontsize  = 10
legend_fontsize = 12

# -------------------- MECHANICAL CALCULATION SETTINGS --------------------
initial_position = 64      # mm
width  = 0.3               # mm
thickness = 0.5            # mm
gauge_length_L0 = 0.1      # mm
# ------------------------------------------------------------------------

# ------------------------- DO NOT TOUCH BELOW ---------------------------
cross_area_A0 = width * thickness

if not file_path.exists():
    raise FileNotFoundError(f"File not found: {file_path}")

ext = file_path.suffix.lower()

if start < 1:
    raise ValueError("'start' must be >= 1")

skip = start - 1

rows = (end - start + 1) if end is not None else None

# ================= FILE TYPE HANDLING =================
if ext in [".xls", ".xlsx"]:
    # Let pandas auto-detect engine (best approach)
    if sheet_colors:
        sheets_to_plot = list(sheet_colors.items())
    else:
        xl = pd.ExcelFile(file_path)
        sheets_to_plot = [(name, None) for name in xl.sheet_names]

elif ext in [".csv", ".mtd"]:
    sheets_to_plot = [(file_path.stem, None)]

else:
    raise ValueError(f"Unsupported file type: {ext}")

# ================= FUNCTION: MAX VALUES =================
def print_max_values(displacement, load, label):
    max_displacement = displacement.max()
    max_load = load.max()

    idx_max_load = load.idxmax()
    displacement_at_max_load = displacement.loc[idx_max_load]

    print(f"\n--- {label} ---")
    print(f"Maximum Displacement: {max_displacement:.5f} mm")
    print(f"Maximum Load: {max_load:.5f} N")
    print(f"Displacement at Max Load: {displacement_at_max_load:.5f} mm")

# ======================= PLOTTING =========================
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))

for sheet_name, color in sheets_to_plot:

    # -------- READ FILE --------
    if ext in [".csv", ".mtd"]:
        try:
            df = pd.read_csv(
                file_path,
                delimiter="\t",   # try tab first
                skiprows=skip,
                nrows=rows,
                header=0,
                skipinitialspace=True,
                on_bad_lines="skip"
            )
        except:
            df = pd.read_csv(
                file_path,
                delim_whitespace=True,  # fallback
                skiprows=skip,
                nrows=rows,
                header=0,
                skipinitialspace=True,
                on_bad_lines="skip"
            )

    else:  # Excel files (.xls, .xlsx)
        df = pd.read_excel(
            file_path,
            sheet_name=sheet_name,
            skiprows=skip,
            nrows=rows,
            header=0
        )

    # Clean column names
    df.columns = [str(c).strip() for c in df.columns]

    # DEBUG (helpful if columns mismatch)
    print(f"\nColumns in {sheet_name}: {df.columns.tolist()}")

    if x_axis not in df.columns or y_axis not in df.columns:
        raise KeyError(
            f"Columns not found. Available columns: {list(df.columns)}"
        )

    displacement = df[x_axis] - initial_position
    load = df[y_axis]

    print_max_values(displacement, load, sheet_name)

    # -------- PLOT 1: LOAD vs DISPLACEMENT --------
    ax1.scatter(
        displacement,
        load,
        label=sheet_name,
        color=color,
        s=15,
        alpha=0.8
    )

    # -------- PLOT 2: STRESS vs STRAIN --------
    strain = displacement / gauge_length_L0
    stress = load / cross_area_A0  # MPa

    ax2.scatter(
        strain,
        stress,
        label=sheet_name,
        color=color,
        s=15,
        alpha=0.8
    )

# ---------------- FORMAT LEFT PLOT ----------------
ax1.set_xlabel("Displacement (mm)", fontsize=label_fontsize)
ax1.set_ylabel("Load (N)", fontsize=label_fontsize)
ax1.set_title("Load vs Displacement", fontsize=title_fontsize)
ax1.tick_params(axis='both', labelsize=tick_fontsize)
ax1.grid(True)

# ---------------- FORMAT RIGHT PLOT ----------------
ax2.set_xlabel("Strain (mm/mm)", fontsize=label_fontsize)
ax2.set_ylabel("Stress (MPa)", fontsize=label_fontsize)
ax2.set_title("Stress vs Strain", fontsize=title_fontsize)
ax2.tick_params(axis='both', labelsize=tick_fontsize)
ax2.grid(True)

# Shared Legend
handles, labels = ax1.get_legend_handles_labels()
if handles:
    fig.legend(handles, labels, fontsize=legend_fontsize, loc="upper center")

plt.tight_layout()
plt.show()
