import pandas as pd
import matplotlib.pyplot as plt
from pathlib import Path

# ----------------------------- USER SETTINGS -----------------------------
file_path = Path(r"C:\MTL32_2020\Data\20260318 Auxetic_Circular2_18_Mar_26_15_09_42.xls")

start = 10
end = None

sheet_colors = {
    #"Sheet10": "red",
    
}

default_color = "blue"  # used if no colors specified

x_axis = "POSITION mm"
y_axis = "LOAD N"

plot_title = "Room T 100 microns"

label_fontsize = 20
title_fontsize = 20
tick_fontsize  = 10
legend_fontsize = 12

# -------------------- MECHANICAL CALCULATION SETTINGS --------------------
initial_position = 12.812
width  = 0.3
thickness = 0.3
gauge_length_L0 = 10
# ------------------------------------------------------------------------

# ------------------------- DO NOT TOUCH BELOW ---------------------------
cross_area_A0 = width * thickness

if not file_path.exists():
    raise FileNotFoundError(f"File not found: {file_path}")

ext = file_path.suffix.lower()

skip = start - 1
rows = (end - start + 1) if end is not None else None

# ================= ENGINE =================
if ext == ".xls":
    excel_engine = "xlrd"
elif ext == ".xlsx":
    excel_engine = "openpyxl"
else:
    excel_engine = None

# ================= FILE HANDLING =================
if ext in [".xls", ".xlsx"]:
    xl = pd.ExcelFile(file_path, engine=excel_engine)

    if sheet_colors:
        sheets_to_plot = list(sheet_colors.items())
        single_color_mode = False
    else:
        sheets_to_plot = [(name, default_color) for name in xl.sheet_names]
        single_color_mode = True

elif ext in [".csv", ".mtd"]:
    sheets_to_plot = [(file_path.stem, default_color)]
    single_color_mode = True

else:
    raise ValueError(f"Unsupported file type: {ext}")

# ================= GLOBAL STORAGE =================
all_displacement = []
all_load = []

# ======================= PLOTTING =========================
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))

for sheet_name, color in sheets_to_plot:

    # -------- READ FILE --------
    if ext in [".csv", ".mtd"]:
        try:
            df = pd.read_csv(
                file_path,
                delimiter="\t",
                skiprows=skip,
                nrows=rows,
                header=0,
                skipinitialspace=True,
                on_bad_lines="skip"
            )
        except:
            df = pd.read_csv(
                file_path,
                delim_whitespace=True,
                skiprows=skip,
                nrows=rows,
                header=0,
                skipinitialspace=True,
                on_bad_lines="skip"
            )
    else:
        df = pd.read_excel(
            file_path,
            sheet_name=sheet_name,
            skiprows=skip,
            nrows=rows,
            header=0,
            engine=excel_engine
        )

    # Clean column names
    df.columns = [str(c).strip() for c in df.columns]

    if x_axis not in df.columns or y_axis not in df.columns:
        raise KeyError(f"Columns not found. Available columns: {list(df.columns)}")

    displacement = df[x_axis] - initial_position
    load = df[y_axis]

    # Store globally
    all_displacement.append(displacement)
    all_load.append(load)

    # -------- MULTI-COLOR MODE --------
    if not single_color_mode:
        ax1.scatter(displacement, load, label=sheet_name, color=color, s=15, alpha=0.8)

        strain = displacement / gauge_length_L0
        stress = load / cross_area_A0

        ax2.scatter(strain, stress, label=sheet_name, color=color, s=15, alpha=0.8)

# ================= SINGLE COLOR MODE =================
if single_color_mode:
    # 🔥 FIX: reset index so idxmax works properly
    all_displacement = pd.concat(all_displacement, ignore_index=True)
    all_load = pd.concat(all_load, ignore_index=True)

    strain = all_displacement / gauge_length_L0
    stress = all_load / cross_area_A0

    # Plot once
    ax1.scatter(all_displacement, all_load, color=default_color, s=15, alpha=0.8)
    ax2.scatter(strain, stress, color=default_color, s=15, alpha=0.8)

    # -------- GLOBAL MAX --------
    max_load = all_load.max()
    idx = all_load.idxmax()
    disp_at_max = all_displacement.loc[idx]

    print("\n=== GLOBAL MAX ACROSS ALL SHEETS ===")
    print(f"Maximum Load: {max_load:.5f} N")
    print(f"Displacement at Max Load: {disp_at_max:.5f} mm")

# ---------------- FORMAT ----------------
ax1.set_xlabel("Displacement (mm)", fontsize=label_fontsize)
ax1.set_ylabel("Load (N)", fontsize=label_fontsize)
ax1.set_title("Load vs Displacement", fontsize=title_fontsize)
ax1.tick_params(axis='both', labelsize=tick_fontsize)
ax1.grid(True)

ax2.set_xlabel("Strain (mm/mm)", fontsize=label_fontsize)
ax2.set_ylabel("Stress (MPa)", fontsize=label_fontsize)
ax2.set_title("Stress vs Strain", fontsize=title_fontsize)
ax2.tick_params(axis='both', labelsize=tick_fontsize)
ax2.grid(True)

# Legend only if multi-color mode
if not single_color_mode:
    handles, labels = ax1.get_legend_handles_labels()
    if handles:
        fig.legend(handles, labels, fontsize=legend_fontsize, loc="upper center")

plt.tight_layout()
plt.show()
