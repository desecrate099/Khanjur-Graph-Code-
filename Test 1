import pandas as pd
import matplotlib.pyplot as plt
from pathlib import Path
from openpyxl.styles import Font
from openpyxl.drawing.image import Image as XLImage
import tempfile

# ============================= USER SETTINGS =============================
file_path = Path(r"C:\Users\sprid\Downloads\20260318 Auxetic_Circular_18_Mar_26_12_04_24.xls")

# Report info
report_name = "Andrew Chen"
report_title = "Auxetic Compression Test Summary"

# ---------------------- TESTING CONDITIONS INPUT ------------------------
test_temperature = "Room Temperature"
test_amperage = "N/A"
test_voltage = "N/A"

# ----------------------- SAMPLE INFORMATION INPUT -----------------------
sample_length = 10.0       # mm
sample_width = 0.3         # mm
sample_thickness = 0.3     # mm

# --------------------------- DATA SETTINGS ------------------------------
start = 10
end = None

sheet_colors = {
    # "Sheet1": "red",
    # "Sheet2": "green",
}
default_color = "blue"

x_axis = "POSITION mm"
y_axis = "LOAD N"

# -------------------------- PLOT SETTINGS -------------------------------
label_fontsize = 20
title_fontsize = 20
tick_fontsize = 10
legend_fontsize = 12

# -------------------- MECHANICAL CALCULATION SETTINGS -------------------
initial_position = 12.812
gauge_length_L0 = 10.0  # mm

# --------------------------- OUTPUT SETTINGS ----------------------------
output_excel = file_path.with_name(file_path.stem + "_processed.xlsx")

# ============================ PREP WORK =================================
cross_area_A0 = sample_width * sample_thickness

if not file_path.exists():
    raise FileNotFoundError(f"File not found: {file_path}")

ext = file_path.suffix.lower()
skip = start - 1
rows = (end - start + 1) if end is not None else None

if ext == ".xls":
    excel_engine = "xlrd"
elif ext == ".xlsx":
    excel_engine = "openpyxl"
else:
    excel_engine = None

# ========================= DETERMINE FILE TYPE ==========================
if ext in [".xls", ".xlsx"]:
    xl = pd.ExcelFile(file_path, engine=excel_engine)

    if sheet_colors:
        sheets_to_plot = list(sheet_colors.items())
        single_color_mode = False
    else:
        sheets_to_plot = [(name, default_color) for name in xl.sheet_names]
        single_color_mode = True

elif ext in [".csv", ".mtd"]:
    sheets_to_plot = [(file_path.stem, default_color)]
    single_color_mode = True

else:
    raise ValueError(f"Unsupported file type: {ext}")

# ========================= STORAGE VARIABLES ============================
all_displacement = []
all_load = []
all_summary_rows = []
combined_export_frames = []

# ============================== PLOTTING ================================
fig1, ax1 = plt.subplots(figsize=(8, 6))
fig2, ax2 = plt.subplots(figsize=(8, 6))

for sheet_name, color in sheets_to_plot:

    # ---------------- READ FILE ----------------
    if ext in [".csv", ".mtd"]:
        try:
            df = pd.read_csv(
                file_path,
                delimiter="\t",
                skiprows=skip,
                nrows=rows,
                header=0,
                skipinitialspace=True,
                on_bad_lines="skip"
            )
        except Exception:
            df = pd.read_csv(
                file_path,
                delim_whitespace=True,
                skiprows=skip,
                nrows=rows,
                header=0,
                skipinitialspace=True,
                on_bad_lines="skip"
            )
    else:
        df = pd.read_excel(
            file_path,
            sheet_name=sheet_name,
            skiprows=skip,
            nrows=rows,
            header=0,
            engine=excel_engine
        )

    # Clean column names
    df.columns = [str(c).strip() for c in df.columns]

    if x_axis not in df.columns or y_axis not in df.columns:
        raise KeyError(
            f"Columns not found in '{sheet_name}'. Available columns: {list(df.columns)}"
        )

    # Convert to numeric and remove bad rows
    df[x_axis] = pd.to_numeric(df[x_axis], errors="coerce")
    df[y_axis] = pd.to_numeric(df[y_axis], errors="coerce")
    df = df.dropna(subset=[x_axis, y_axis]).reset_index(drop=True)

    # Calculations
    displacement = df[x_axis] - initial_position
    load = df[y_axis]
    strain = displacement / gauge_length_L0
    stress = load / cross_area_A0

    # Store export data
    export_df = pd.DataFrame({
        "Sheet": sheet_name,
        "Displacement (mm)": displacement,
        "Load (N)": load,
        "Strain (mm/mm)": strain,
        "Stress (MPa)": stress
    })
    combined_export_frames.append(export_df)

    # Store global data
    all_displacement.append(displacement)
    all_load.append(load)

    # Per-sheet summary
    max_load = load.max()
    max_disp = displacement.max()
    idx_max_load = load.idxmax()
    disp_at_max_load = displacement.loc[idx_max_load]
    max_stress = stress.max()
    max_strain = strain.max()

    all_summary_rows.append({
        "Sheet": sheet_name,
        "Max Displacement (mm)": max_disp,
        "Max Load (N)": max_load,
        "Displacement at Max Load (mm)": disp_at_max_load,
        "Max Strain (mm/mm)": max_strain,
        "Max Stress (MPa)": max_stress
    })

    # Plot
    label_name = sheet_name if not single_color_mode else None
    ax1.scatter(displacement, load, label=label_name, color=color, s=15, alpha=0.8)
    ax2.scatter(strain, stress, label=label_name, color=color, s=15, alpha=0.8)

# =========================== GLOBAL SUMMARY =============================
all_displacement = pd.concat(all_displacement, ignore_index=True)
all_load = pd.concat(all_load, ignore_index=True)

global_strain = all_displacement / gauge_length_L0
global_stress = all_load / cross_area_A0

global_max_load = all_load.max()
global_max_disp = all_displacement.max()
global_idx = all_load.idxmax()
global_disp_at_max_load = all_displacement.loc[global_idx]
global_max_strain = global_strain.max()
global_max_stress = global_stress.max()

all_summary_rows.append({
    "Sheet": "GLOBAL",
    "Max Displacement (mm)": global_max_disp,
    "Max Load (N)": global_max_load,
    "Displacement at Max Load (mm)": global_disp_at_max_load,
    "Max Strain (mm/mm)": global_max_strain,
    "Max Stress (MPa)": global_max_stress
})

summary_df = pd.DataFrame(all_summary_rows)
combined_data_df = pd.concat(combined_export_frames, ignore_index=True)

print("\n=== GLOBAL MAX ACROSS ALL SHEETS ===")
print(f"Maximum Load: {global_max_load:.5f} N")
print(f"Maximum Displacement: {global_max_disp:.5f} mm")
print(f"Displacement at Max Load: {global_disp_at_max_load:.5f} mm")
print(f"Maximum Stress: {global_max_stress:.5f} MPa")
print(f"Maximum Strain: {global_max_strain:.5f}")

# ============================ FORMAT PLOTS ==============================
ax1.set_xlabel("Displacement (mm)", fontsize=label_fontsize)
ax1.set_ylabel("Load (N)", fontsize=label_fontsize)
ax1.set_title("Load vs Displacement", fontsize=title_fontsize)
ax1.tick_params(axis="both", labelsize=tick_fontsize)
ax1.grid(True)

ax2.set_xlabel("Strain (mm/mm)", fontsize=label_fontsize)
ax2.set_ylabel("Stress (MPa)", fontsize=label_fontsize)
ax2.set_title("Stress vs Strain", fontsize=title_fontsize)
ax2.tick_params(axis="both", labelsize=tick_fontsize)
ax2.grid(True)

if not single_color_mode:
    ax1.legend(fontsize=legend_fontsize)
    ax2.legend(fontsize=legend_fontsize)

fig1.tight_layout()
fig2.tight_layout()

# ========================== SAVE PLOT IMAGES ============================
temp_dir = Path(tempfile.gettempdir())
plot1_path = temp_dir / "load_vs_displacement.png"
plot2_path = temp_dir / "stress_vs_strain.png"

fig1.savefig(plot1_path, dpi=200, bbox_inches="tight")
fig2.savefig(plot2_path, dpi=200, bbox_inches="tight")

# ============================ WRITE TO EXCEL ============================
with pd.ExcelWriter(output_excel, engine="openpyxl") as writer:
    combined_data_df.to_excel(writer, sheet_name="Data", index=False, startrow=0)
    summary_df.to_excel(writer, sheet_name="Summary", index=False, startrow=16)

    workbook = writer.book
    ws_data = workbook["Data"]
    ws_summary = workbook["Summary"]

    # Fonts
    bold_font = Font(bold=True)
    big_bold_font = Font(bold=True, size=16)
    medium_bold_font = Font(bold=True, size=12)

    # Data sheet header bold
    for cell in ws_data[1]:
        cell.font = bold_font

    # Summary table header is row 17 because startrow=16
    for cell in ws_summary[17]:
        cell.font = bold_font

    # ================= TOP OF SUMMARY PAGE =================
    ws_summary["A1"] = report_title
    ws_summary["A1"].font = big_bold_font

    ws_summary["A2"] = f"Prepared by: {report_name}"
    ws_summary["A2"].font = medium_bold_font

    # ================= TESTING CONDITIONS =================
    ws_summary["A4"] = "Testing Conditions"
    ws_summary["A4"].font = medium_bold_font

    ws_summary["A5"] = "Temperature"
    ws_summary["B5"] = test_temperature

    ws_summary["A6"] = "Amperage"
    ws_summary["B6"] = test_amperage

    ws_summary["A7"] = "Voltage"
    ws_summary["B7"] = test_voltage

    for row in range(5, 8):
        ws_summary[f"A{row}"].font = bold_font

    # ================= SAMPLE INFORMATION =================
    ws_summary["D4"] = "Sample Information"
    ws_summary["D4"].font = medium_bold_font

    ws_summary["D5"] = "Length (mm)"
    ws_summary["E5"] = sample_length

    ws_summary["D6"] = "Width (mm)"
    ws_summary["E6"] = sample_width

    ws_summary["D7"] = "Thickness / Height (mm)"
    ws_summary["E7"] = sample_thickness

    ws_summary["D8"] = "Gauge Length L0 (mm)"
    ws_summary["E8"] = gauge_length_L0

    ws_summary["D9"] = "Cross-sectional Area A0 (mm^2)"
    ws_summary["E9"] = cross_area_A0

    for row in range(5, 10):
        ws_summary[f"D{row}"].font = bold_font

    # ================= IMPORTANT RESULTS =================
    ws_summary["J1"] = "Important Results"
    ws_summary["J1"].font = big_bold_font

    ws_summary["J3"] = "Global Max Load (N)"
    ws_summary["K3"] = global_max_load

    ws_summary["J4"] = "Global Max Displacement (mm)"
    ws_summary["K4"] = global_max_disp

    ws_summary["J5"] = "Displacement at Max Load (mm)"
    ws_summary["K5"] = global_disp_at_max_load

    ws_summary["J6"] = "Global Max Stress (MPa)"
    ws_summary["K6"] = global_max_stress

    ws_summary["J7"] = "Global Max Strain (mm/mm)"
    ws_summary["K7"] = global_max_strain

    for row in range(3, 8):
        ws_summary[f"J{row}"].font = bold_font

    # ================= SUMMARY LABEL =================
    ws_summary["A16"] = "Summary Data"
    ws_summary["A16"].font = medium_bold_font

    # Column widths
    ws_data.column_dimensions["A"].width = 18
    ws_data.column_dimensions["B"].width = 20
    ws_data.column_dimensions["C"].width = 15
    ws_data.column_dimensions["D"].width = 18
    ws_data.column_dimensions["E"].width = 15

    ws_summary.column_dimensions["A"].width = 22
    ws_summary.column_dimensions["B"].width = 20
    ws_summary.column_dimensions["D"].width = 28
    ws_summary.column_dimensions["E"].width = 20
    ws_summary.column_dimensions["J"].width = 30
    ws_summary.column_dimensions["K"].width = 20

    # Insert graphs
    img1 = XLImage(str(plot1_path))
    img2 = XLImage(str(plot2_path))

    img1.width = 600
    img1.height = 400
    img2.width = 600
    img2.height = 400

    ws_summary.add_image(img1, "J10")
    ws_summary.add_image(img2, "J32")

print(f"\nExcel file created successfully:\n{output_excel}")

# Show plots after export
plt.show()
